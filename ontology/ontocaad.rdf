  <rdf:Description rdf:about="https://w3id.org/ontocaad#Feature_Details">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/ontocaad#Feature"/>
    <rdfs:label xml:lang="en">Details</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#hasAgentRole">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">has agent role</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/ontocaad#Agent"/>
    <rdfs:range rdf:resource="https://w3id.org/ontocaad#AgentRole"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#Artefact_SketchupImage">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/ontocaad#Artefact"/>
    <rdfs:label xml:lang="en">Sketchup model line drawing</rdfs:label>
    <oc:hasArtefactType rdf:resource="https://w3id.org/ontocaad#AT_Digital3DModel"/>
    <oc:hasDataType rdf:resource="https://w3id.org/ontocaad#DT_VisualVectorial"/>
    <oc:isDigital rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</oc:isDigital>
    <oc:isIterative rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</oc:isIterative>
    <oc:isExternal rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</oc:isExternal>
    <oc:hasFeature rdf:resource="https://w3id.org/ontocaad#Feature_Geometry"/>
    <oc:createdBy rdf:resource="https://w3id.org/ontocaad#Designer_Lead"/>
    <oc:createdInStage rdf:resource="https://w3id.org/ontocaad#Stage_PrelimDesign"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#Designer_Colleague1">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/ontocaad#Person"/>
    <rdfs:label xml:lang="en">Colleague Designer</rdfs:label>
    <oc:hasRole rdf:resource="https://w3id.org/ontocaad#Role_Designer"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#DesignStage">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">DesignStage</rdfs:label>
    <skos:definition xml:lang="en">Different stages in the architectural design process.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#Designer_Lead">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/ontocaad#Person"/>
    <rdfs:label xml:lang="en">Lead Designer</rdfs:label>
    <oc:hasRole rdf:resource="https://w3id.org/ontocaad#Role_Designer"/>
    <oc:reframes rdf:resource="https://w3id.org/ontocaad#Problem_FacadeMateriality"/>
    <oc:interacts rdf:resource="https://w3id.org/ontocaad#Agent_DiffusionModel"/>
    <oc:interacts rdf:resource="https://w3id.org/ontocaad#Designer_Colleague1"/>
    <oc:interprets rdf:resource="https://w3id.org/ontocaad#Feature_Style"/>
    <oc:interprets rdf:resource="https://w3id.org/ontocaad#Feature_ColourScheme"/>
    <oc:interprets rdf:resource="https://w3id.org/ontocaad#Feature_Materiality"/>
    <oc:reasons rdf:resource="https://w3id.org/ontocaad#Decision_VermilionCornice"/>
    <oc:makes rdf:resource="https://w3id.org/ontocaad#Decision_VermilionCornice"/>
    <oc:implements rdf:resource="https://w3id.org/ontocaad#Decision_VermilionCornice"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#AT_BillOfQuantities">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/ontocaad#ArtefactType"/>
    <rdfs:label xml:lang="en">Bill of Quantities</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#State_SketchupModel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/ontocaad#ProjectState"/>
    <rdfs:label xml:lang="en">Sketchup model of residential building</rdfs:label>
    <oc:stateDescription xml:lang="en">3D Sketchup model representing current design state.</oc:stateDescription>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#Feature_Materiality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/ontocaad#Feature"/>
    <rdfs:label xml:lang="en">Materiality</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#AT_Photograph">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/ontocaad#ArtefactType"/>
    <rdfs:label xml:lang="en">Photograph</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#interprets">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">interprets</rdfs:label>
    <rdfs:comment xml:lang="en">An actor uses analytical techniques to extract design features from
    artefacts. Person can analyse visually; Agent can use ML techniques. When Agent is a
    diffusion model, interpretations can be textual, visual, or spatial in nature.</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/ontocaad#Actor"/>
    <rdfs:range rdf:resource="https://w3id.org/ontocaad#Feature"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#AgentRole_DecisionMaker">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/ontocaad#AgentRole"/>
    <rdfs:label xml:lang="en">Decision Maker</rdfs:label>
    <skos:definition xml:lang="en">Deciding, aligned with epistemic pipeline human [6-7], machine [7].</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#interacts">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdfs:label xml:lang="en">interacts</rdfs:label>
    <rdfs:comment xml:lang="en">Actors can interact with one another; be it instances of Person or Agent.
    The interact() function can be programmed differently for different Agent instances.</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/ontocaad#Actor"/>
    <rdfs:range rdf:resource="https://w3id.org/ontocaad#Actor"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#AgentRole">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">AgentRole</rdfs:label>
    <skos:definition xml:lang="en">Different roles an Agent can have within the design process.
    Aligned with the epistemic pipeline categories: reframing information,
    internal reasoning, and deciding.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#Artefact_FacadeVariant2">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
