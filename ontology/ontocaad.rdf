    <oc:hasArtefactType rdf:resource="https://w3id.org/ontocaad#AT_GeneratedImage"/>
    <oc:hasDataType rdf:resource="https://w3id.org/ontocaad#DT_VisualRaster"/>
    <oc:isDigital rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</oc:isDigital>
    <oc:isIterative rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</oc:isIterative>
    <oc:isExternal rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</oc:isExternal>
    <oc:hasFeature rdf:resource="https://w3id.org/ontocaad#Feature_Style"/>
    <oc:hasFeature rdf:resource="https://w3id.org/ontocaad#Feature_Materiality"/>
    <oc:hasFeature rdf:resource="https://w3id.org/ontocaad#Feature_ColourScheme"/>
    <oc:createdBy rdf:resource="https://w3id.org/ontocaad#Agent_DiffusionModel"/>
    <oc:createdInStage rdf:resource="https://w3id.org/ontocaad#Stage_PrelimDesign"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#DT_VisualVectorial">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/ontocaad#DataType"/>
    <rdfs:label xml:lang="en">Visual - Vectorial</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#Agent_DiffusionModel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/ontocaad#Agent"/>
    <rdfs:label xml:lang="en">Diffusion Model Agent</rdfs:label>
    <oc:hasAgentRole rdf:resource="https://w3id.org/ontocaad#AgentRole_Reasoner"/>
    <oc:hasAgentDataType rdf:resource="https://w3id.org/ontocaad#DT_VisualRaster"/>
    <oc:hasAgentDataType rdf:resource="https://w3id.org/ontocaad#DT_Textual"/>
    <oc:hasSpecialisation rdf:resource="https://w3id.org/ontocaad#Feature_Style"/>
    <oc:hasSpecialisation rdf:resource="https://w3id.org/ontocaad#Feature_Texture"/>
    <oc:hasSpecialisation rdf:resource="https://w3id.org/ontocaad#Feature_Materiality"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#AT_PhysicalModel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/ontocaad#ArtefactType"/>
    <rdfs:label xml:lang="en">Physical Model</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#Artefact_FacadeVariant3">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/ontocaad#Artefact"/>
    <rdfs:label xml:lang="en">Facade variant 3 — vermilion red cornice</rdfs:label>
    <oc:hasArtefactType rdf:resource="https://w3id.org/ontocaad#AT_GeneratedImage"/>
    <oc:hasDataType rdf:resource="https://w3id.org/ontocaad#DT_VisualRaster"/>
    <oc:isDigital rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</oc:isDigital>
    <oc:isIterative rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</oc:isIterative>
    <oc:isExternal rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</oc:isExternal>
    <oc:hasFeature rdf:resource="https://w3id.org/ontocaad#Feature_Style"/>
    <oc:hasFeature rdf:resource="https://w3id.org/ontocaad#Feature_Materiality"/>
    <oc:hasFeature rdf:resource="https://w3id.org/ontocaad#Feature_ColourScheme"/>
    <oc:createdBy rdf:resource="https://w3id.org/ontocaad#Agent_DiffusionModel"/>
    <oc:createdInStage rdf:resource="https://w3id.org/ontocaad#Stage_PrelimDesign"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#DesignDecision">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">DesignDecision</rdfs:label>
    <skos:definition xml:lang="en">A design decision regarding the requirements and intentions of a
    DesignProblem. Contains arguments for and against making that decision and can update
    the ProjectState to implement that decision.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#hasDataType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">has data type</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/ontocaad#Artefact"/>
    <rdfs:range rdf:resource="https://w3id.org/ontocaad#DataType"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#AT_Digital3DModel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/ontocaad#ArtefactType"/>
    <rdfs:label xml:lang="en">Digital 3D Model</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#Feature_SpatialRelationships">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/ontocaad#Feature"/>
    <rdfs:label xml:lang="en">Spatial Relationships</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#isExternal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">is external communication</rdfs:label>
    <rdfs:comment xml:lang="en">Whether the artefact serves external communication (e.g. client).</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/ontocaad#Artefact"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#Decision_VermilionCornice">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/ontocaad#DesignDecision"/>
    <rdfs:label xml:lang="en">Choose vermilion red cornice variant</rdfs:label>
    <oc:argumentsFor rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Striking vermilion red cornice creates visual identity.
    Neutral brickwork blends with streetscape. Contemporary concrete bay window
    adds modern element. The designer stated they would never have proposed red
    themselves — the diffusion model added creative value.</oc:argumentsFor>
    <oc:argumentsAgainst rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bold colour may not suit all clients.</oc:argumentsAgainst>
    <oc:updatesState rdf:resource="https://w3id.org/ontocaad#State_UpdatedModel"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#createdInStage">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">created in stage</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/ontocaad#Artefact"/>
    <rdfs:range rdf:resource="https://w3id.org/ontocaad#DesignStage"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#creates">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">creates</rdfs:label>
    <rdfs:comment xml:lang="en">Person could draw or create a digital 3D model; Agent could compute
    structural calculations, generate atmospheric visualisations or propose spatial
    configurations.</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/ontocaad#Actor"/>
    <rdfs:range rdf:resource="https://w3id.org/ontocaad#Artefact"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#Feature">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Feature</rdfs:label>
    <skos:definition xml:lang="en">Embedded architectural design features within artefacts are the
    building blocks with which design decisions are made. The actor creates an artefact,
    interprets its embedded features, and considers these features when reasoning to make
    a design decision. As features are building blocks, there is no further class hierarchy.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#implements">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">implements</rdfs:label>
    <rdfs:comment xml:lang="en">After a design decision has been made, the decision can be implemented.
    Triggers the update of ProjectState.</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/ontocaad#Actor"/>
    <rdfs:range rdf:resource="https://w3id.org/ontocaad#DesignDecision"/>
  </rdf:Description>
