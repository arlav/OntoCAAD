  <rdf:Description rdf:about="https://w3id.org/ontocaad#hasFeature">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">has feature</rdfs:label>
    <rdfs:comment xml:lang="en">Which features are embedded in the artefact.</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/ontocaad#Artefact"/>
