    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/ontocaad#Feature"/>
    <rdfs:label xml:lang="en">Texture</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#currentState">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">current state</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/ontocaad#DesignProject"/>
    <rdfs:range rdf:resource="https://w3id.org/ontocaad#ProjectState"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#hasRole">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">has role</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/ontocaad#Person"/>
    <rdfs:range rdf:resource="https://w3id.org/ontocaad#Role"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#Artefact">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Artefact</rdfs:label>
    <skos:definition xml:lang="en">A design artefact produced during the design process. Properties
    include: type, data type, whether digital, iterative, or for external communication,
    which features are embedded, who created it, and in which design stage.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#Role_Manager">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/ontocaad#Role"/>
    <rdfs:label xml:lang="en">Manager</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#currentStage">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">current stage</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/ontocaad#DesignProject"/>
    <rdfs:range rdf:resource="https://w3id.org/ontocaad#DesignStage"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#ProjectState">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">ProjectState</rdfs:label>
    <skos:definition xml:lang="en">Continuously tracks the versions of the project. Updated when a
    DesignDecision is implemented.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#hasDecision">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">has decision</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/ontocaad#DesignProblem"/>
    <rdfs:range rdf:resource="https://w3id.org/ontocaad#DesignDecision"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#Role_Engineer">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/ontocaad#Role"/>
    <rdfs:label xml:lang="en">Engineer</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#createdBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">created by</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/ontocaad#Artefact"/>
    <rdfs:range rdf:resource="https://w3id.org/ontocaad#Actor"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#Feature_Geometry">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/ontocaad#Feature"/>
    <rdfs:label xml:lang="en">Geometry</rdfs:label>
  </rdf:Description>
</rdf:RDF>
