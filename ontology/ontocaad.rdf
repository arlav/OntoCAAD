    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/ontocaad#Artefact"/>
    <rdfs:label xml:lang="en">Facade variant 4 — terracotta tones</rdfs:label>
    <oc:hasArtefactType rdf:resource="https://w3id.org/ontocaad#AT_GeneratedImage"/>
    <oc:hasDataType rdf:resource="https://w3id.org/ontocaad#DT_VisualRaster"/>
    <oc:isDigital rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</oc:isDigital>
    <oc:isIterative rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</oc:isIterative>
    <oc:isExternal rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</oc:isExternal>
    <oc:hasFeature rdf:resource="https://w3id.org/ontocaad#Feature_Style"/>
    <oc:hasFeature rdf:resource="https://w3id.org/ontocaad#Feature_Materiality"/>
    <oc:hasFeature rdf:resource="https://w3id.org/ontocaad#Feature_ColourScheme"/>
    <oc:createdBy rdf:resource="https://w3id.org/ontocaad#Agent_DiffusionModel"/>
    <oc:createdInStage rdf:resource="https://w3id.org/ontocaad#Stage_PrelimDesign"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#reasons">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">reasons</rdfs:label>
    <rdfs:comment xml:lang="en">Internal reasoning: three steps: (i) create artefact representing
    relevant features, (ii) extract feature information from artefact, (iii) summarise
    decision-making arguments. Based on Schön's reflective practitioner: reasoning
    happens through interaction with a design artefact.</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/ontocaad#Actor"/>
    <rdfs:range rdf:resource="https://w3id.org/ontocaad#DesignDecision"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#DT_Textual">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/ontocaad#DataType"/>
    <rdfs:label xml:lang="en">Textual</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#Artefact_FacadeVariant1">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/ontocaad#Artefact"/>
    <rdfs:label xml:lang="en">Facade variant 1 — beige brickwork</rdfs:label>
    <oc:hasArtefactType rdf:resource="https://w3id.org/ontocaad#AT_GeneratedImage"/>
    <oc:hasDataType rdf:resource="https://w3id.org/ontocaad#DT_VisualRaster"/>
    <oc:isDigital rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</oc:isDigital>
    <oc:isIterative rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</oc:isIterative>
    <oc:isExternal rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</oc:isExternal>
    <oc:hasFeature rdf:resource="https://w3id.org/ontocaad#Feature_Style"/>
    <oc:hasFeature rdf:resource="https://w3id.org/ontocaad#Feature_Materiality"/>
    <oc:hasFeature rdf:resource="https://w3id.org/ontocaad#Feature_ColourScheme"/>
    <oc:createdBy rdf:resource="https://w3id.org/ontocaad#Agent_DiffusionModel"/>
    <oc:createdInStage rdf:resource="https://w3id.org/ontocaad#Stage_PrelimDesign"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#AT_Section">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/ontocaad#ArtefactType"/>
    <rdfs:label xml:lang="en">Section</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#requirement">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">requirement</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/ontocaad#DesignProblem"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#AT_ReferenceImage">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/ontocaad#ArtefactType"/>
    <rdfs:label xml:lang="en">Reference Image</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#DT_Numerical">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/ontocaad#DataType"/>
    <rdfs:label xml:lang="en">Numerical</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#stateDescription">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">state description</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/ontocaad#ProjectState"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#Stage_PrelimDesign">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/ontocaad#DesignStage"/>
    <rdfs:label xml:lang="en">Preliminary Design</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#Actor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Actor</rdfs:label>
    <skos:definition xml:lang="en">A superclass for entities that participate in the design process.
    Has two subclasses: Person and Agent, who can interact with one another. An Actor
    can create an Artefact, interpret a Feature, reframe a DesignProblem, reason on a
    DesignDecision, make a DesignDecision, and implement a DesignDecision.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#AT_GeneratedImage">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/ontocaad#ArtefactType"/>
    <rdfs:label xml:lang="en">Generated Image</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#ArtefactType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">ArtefactType</rdfs:label>
    <skos:definition xml:lang="en">Different types of artefacts in the design process.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#Role_Client">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/ontocaad#Role"/>
    <rdfs:label xml:lang="en">Client</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#argumentsFor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">arguments for</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/ontocaad#DesignDecision"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#DT_Graph">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/ontocaad#DataType"/>
    <rdfs:label xml:lang="en">Graph</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#makes">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">makes</rdfs:label>
    <rdfs:comment xml:lang="en">Deciding: the actor makes a design decision based on the arguments.</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/ontocaad#Actor"/>
    <rdfs:range rdf:resource="https://w3id.org/ontocaad#DesignDecision"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#Person">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/ontocaad#Actor"/>
    <rdfs:label xml:lang="en">Person</rdfs:label>
    <skos:definition xml:lang="en">A human participant in the design process. Has a Role attribute.
    Uses deductive, inductive, or abductive reasoning. Gathers sensory and social
    information, constructs meaningful models through perception, and incorporates
    tacit and embodied knowledge.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <owl:versionInfo>1.0.0</owl:versionInfo>
    <rdfs:label xml:lang="en">OntoCAAD</rdfs:label>
    <dcterms:title xml:lang="en">OntoCAAD: an empirically grounded Ontology for Collaborative Agentic Architectural Design</dcterms:title>
    <dcterms:description xml:lang="en">A proof-of-concept ontology that can be used as a foundation for
    the development of collaborative AI agents that can assist with specific architectural
    design tasks, considering both human and machine reasoning. Built using the Ontology
    Building 101 methodology (Noy &amp; McGuinness, 2001) and grounded in empirical data from
    a Flemish design firm living lab and educational experiments with diffusion models.</dcterms:description>
    <dcterms:creator>Elien Vissers-Similon</dcterms:creator>
    <dcterms:contributor>Theodoros Dounas</dcterms:contributor>
    <dcterms:source>Vissers-Similon, De Walsche &amp; Dounas, 2026 (mapping method, industry data)</dcterms:source>
    <dcterms:source>Vissers-Similon &amp; Dounas, 2026 (educational experiments)</dcterms:source>
    <dcterms:source>Quattrociocchi, Capraro &amp; Perc, 2025 (epistemic pipelines)</dcterms:source>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#Agent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/ontocaad#Actor"/>
    <rdfs:label xml:lang="en">Agent</rdfs:label>
    <skos:definition xml:lang="en">A collaborative AI agent that assists with architectural design tasks.
    Has attributes: AgentRole, DataType, and specialisation (one or more design features).
    Dependent on the input information provided. The machine reasoning follows the epistemic
    pipeline: reframing information [1], internal reasoning [2-6], deciding [7].</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#Feature_ColourScheme">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/ontocaad#Feature"/>
    <rdfs:label xml:lang="en">Colour Scheme</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#relatedFeature">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">related feature</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/ontocaad#DesignProblem"/>
    <rdfs:range rdf:resource="https://w3id.org/ontocaad#Feature"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#hasAgentDataType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">has agent data type</rdfs:label>
    <rdfs:comment xml:lang="en">The data types the agent can process.</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/ontocaad#Agent"/>
    <rdfs:range rdf:resource="https://w3id.org/ontocaad#DataType"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#Project_FacadeDesign">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/ontocaad#DesignProject"/>
    <rdfs:label xml:lang="en">Facade Design — Residential Building, Flanders</rdfs:label>
    <oc:currentStage rdf:resource="https://w3id.org/ontocaad#Stage_PrelimDesign"/>
    <oc:hasRequirement rdf:resource="https://w3id.org/ontocaad#Problem_FacadeMateriality"/>
    <oc:currentState rdf:resource="https://w3id.org/ontocaad#State_SketchupModel"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#DT_VisualRaster">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/ontocaad#DataType"/>
    <rdfs:label xml:lang="en">Visual - Raster</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#AT_MoodBoard">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/ontocaad#ArtefactType"/>
    <rdfs:label xml:lang="en">Mood Board</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#AgentRole_Reasoner">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/ontocaad#AgentRole"/>
    <rdfs:label xml:lang="en">Reasoner</rdfs:label>
    <skos:definition xml:lang="en">Internal reasoning, aligned with epistemic pipeline human [5], machine [2-6].</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#AT_Floorplan">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/ontocaad#ArtefactType"/>
    <rdfs:label xml:lang="en">Floorplan</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#Role_Designer">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/ontocaad#Role"/>
    <rdfs:label xml:lang="en">Designer</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#AgentRole_Implementor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/ontocaad#AgentRole"/>
    <rdfs:label xml:lang="en">Implementor</rdfs:label>
    <skos:definition xml:lang="en">Implements design decisions into artefacts or project state.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#DesignProject">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">DesignProject</rdfs:label>
    <skos:definition xml:lang="en">Modelled as a state machine with three properties: the current state,
    the current design stage, and a list of all design requirements. The iterative nature
    of design processes is captured through the state machine model.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#DesignProblem">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">DesignProblem</rdfs:label>
    <skos:definition xml:lang="en">A design requirement, its related features and the design intentions
    to adhere to the requirements. For example, the requirement could be that the kitchen
    should border the living room, the intention an open-concept living, and the related
    feature spatial relationships.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#hasArtefactType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">has artefact type</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/ontocaad#Artefact"/>
    <rdfs:range rdf:resource="https://w3id.org/ontocaad#ArtefactType"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#Role">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Role</rdfs:label>
    <skos:definition xml:lang="en">Different roles a Person can have within the design process.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#Feature_Feeling">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/ontocaad#Feature"/>
    <rdfs:label xml:lang="en">Feeling</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#State_UpdatedModel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/ontocaad#ProjectState"/>
    <rdfs:label xml:lang="en">Updated Sketchup model with vermilion cornice</rdfs:label>
    <oc:stateDescription xml:lang="en">Sketchup model updated with chosen facade materiality.</oc:stateDescription>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#Stage_PreDesign">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/ontocaad#DesignStage"/>
    <rdfs:label xml:lang="en">Pre-Design</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#DataType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">DataType</rdfs:label>
    <skos:definition xml:lang="en">Types of data representation.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#Problem_FacadeMateriality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/ontocaad#DesignProblem"/>
    <rdfs:label xml:lang="en">Facade materiality and colour scheme</rdfs:label>
    <oc:requirement rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Brick and concrete materiality for the facade</oc:requirement>
    <oc:intention rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The colour scheme needs to match the streetscape, but also stand out</oc:intention>
    <oc:relatedFeature rdf:resource="https://w3id.org/ontocaad#Feature_ColourScheme"/>
    <oc:relatedFeature rdf:resource="https://w3id.org/ontocaad#Feature_Style"/>
    <oc:relatedFeature rdf:resource="https://w3id.org/ontocaad#Feature_Materiality"/>
    <oc:hasDecision rdf:resource="https://w3id.org/ontocaad#Decision_VermilionCornice"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#reframes">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">reframes</rdfs:label>
    <rdfs:comment xml:lang="en">Reframing information: Person gathers sensory/social information,
    constructs meaningful model, incorporates tacit knowledge. Agent is dependent on
    input information. Analyses DesignProject to identify a requirement, creates
    DesignProblem instance, attributes relevant features.</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/ontocaad#Actor"/>
    <rdfs:range rdf:resource="https://w3id.org/ontocaad#DesignProblem"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#isIterative">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">is iterative</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/ontocaad#Artefact"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#isDigital">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">is digital</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/ontocaad#Artefact"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#updatesState">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">updates state</rdfs:label>
    <rdfs:comment xml:lang="en">A DesignDecision, when implemented, updates the ProjectState.</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/ontocaad#DesignDecision"/>
    <rdfs:range rdf:resource="https://w3id.org/ontocaad#ProjectState"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#Feature_Style">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/ontocaad#Feature"/>
    <rdfs:label xml:lang="en">Style</rdfs:label>
  </rdf:Description>
