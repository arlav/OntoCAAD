  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/ontocaad#hasSpecialisation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">has specialisation</rdfs:label>
    <rdfs:comment xml:lang="en">One or more design features the agent specialises in.</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/ontocaad#Agent"/>
    <rdfs:range rdf:resource="https://w3id.org/ontocaad#Feature"/>
  </rdf:Description>
